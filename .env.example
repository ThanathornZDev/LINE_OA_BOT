# LINE Messaging API
CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# PromptPay receiver (mobile number 10 digits or national ID 13 digits)
PROMPTPAY_ID=0812345678

# Public HTTPS URL of this server, used for sending QR image URL to LINE
# Example: https://your-domain.com
BASE_URL=https://your-domain.com

# Flask
PORT=8000
SECRET_KEY=change-this-secret-key

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
# Optional: use hash instead of plain password (takes priority over ADMIN_PASSWORD)
# ADMIN_PASSWORD_HASH=pbkdf2:sha256:...

# Secret code for forgot-password flow
ADMIN_SECRET_CODE=CHANGE_ME_SECRET_CODE
# Optional: use hash instead of plain secret code (takes priority over ADMIN_SECRET_CODE)
# ADMIN_SECRET_CODE_HASH=pbkdf2:sha256:...
